generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FoodType {
  VEG
  NON_VEG
}

enum OrderStatus {
  PLACED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  CANCELLED
  FAILED
  SUCCESS
}

model Category {
  id       String  @id @default(uuid())
  name     String
  isActive Boolean

  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  type        FoodType

  isFeatured  Boolean @default(false)
  isAvailable Boolean @default(true)

  categoryId String
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

model Order {
  id          String @id @default(uuid())
  phone       String
  tableNumber String
  total       Float

  orderStatus   OrderStatus   @default(PLACED)
  paymentStatus PaymentStatus @default(PENDING)

  orderItem OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  itemId   String
  quantity Int
  price    Float

  order Order @relation(fields: [orderId], references: [id])
  item  Item  @relation(fields: [itemId], references: [id])
}
